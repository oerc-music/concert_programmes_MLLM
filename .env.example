# Copy this file to ".env" and fill in your Gemini API key.
# ".env" is listed in .gitignore and is never committed.
#
# You can also skip this file entirely and paste your key directly into the
# app -- it is only held in memory for that session and is never written to disk.
#
# Get a free Gemini key at: https://aistudio.google.com/apikey
# (see README "How to get an API key")

GEMINI_API_KEY=
